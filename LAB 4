#include <stdio.h>    
#include <pthread.h>    
#include <semaphore.h>    
#include <unistd.h>  
#define N 5  sem_t 
forks[N];  pthread_t philosophers[N];  void* 
philosopher(void* num) {  int id = *(int*)num;  
prin ("Philosopher %d is thinking\n", id);  
sleep(1);  
sem_wait(&forks[id]);  
sem_wait(&forks[(id + 1) % N]);      
prin 
("Philosopher %d is ea ng\n", id);      
sleep(1);      
sem_post(&forks[id]);      
sem_post(&forks[(id 
+ 1) % N]);      prin ("Philosopher %d finished ea 
ng\n",  
id);      
return NULL;    
}    
int main() {      
int i, id[N];    
for (i = 0; i < N; i++)          
sem_init(&forks[i], 0, 1);      
for (i = 0; i < N; i++) {          
id[i] = i;    
pthread_create(&philosophers[i], NULL, philosopher, &id[i]);    
}       
for (i = 0; i < 
N; i++)           
pthread_join(philosophers[i], NULL);      
return 0;    
} 
